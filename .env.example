# Lokal: salin ke .env.local — Vercel: Settings → Environment Variables (Production & Preview).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
DIRECT_URL=
# Opsional: true = Prisma pakai DIRECT_URL (sesi Postgres), hindari error 08P01 lewat transaction pooler di dev.
# PRISMA_DATABASE_USE_DIRECT=true

# Opsional: batasi login ke email tertentu (pisahkan koma). Kosong = semua user Supabase Auth yang valid.
# ALLOWED_APP_EMAILS=anda@email.com
