// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id           String     @id @default(cuid())
  code         String     @unique
  name         String
  category     String
  size         String
  unit         String
  defaultPrice Decimal    @db.Decimal(14, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  saleItems    SaleItem[]
}

model VeneerTemplate {
  id           String   @id @default(cuid())
  customerId   String
  templateName String
  specKey      String
  thickness    String?
  width        String?
  length       String?
  grade        String?
  unit         String?
  defaultPrice Decimal? @db.Decimal(14, 2)
  isActive     Boolean  @default(true)
  source       String   @default("auto")
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([customerId, specKey])
  @@index([customerId])
  @@index([isActive])
}

model Customer {
  id                 String              @id @default(cuid())
  name               String              @unique
  sales              Sale[]
  invoiceGroups      InvoiceGroup[]
  customerPriceLists CustomerPriceList[]
  veneerTemplates    VeneerTemplate[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model CustomerPriceList {
  id           String   @id @default(cuid())
  customerId   String
  itemKey      String
  itemName     String
  category     String?
  thickness    String?
  width        String?
  length       String?
  unit         String?
  latestPrice  Decimal  @db.Decimal(14, 2)
  lastSaleDate DateTime
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([customerId, itemKey])
  @@index([customerId])
}

model Vendor {
  id            String         @id @default(cuid())
  name          String         @unique
  woodPurchases WoodPurchase[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model WoodPurchase {
  id               String                         @id @default(cuid())
  clientRequestId  String?                        @unique
  vendorId         String
  purchaseDate     DateTime
  batchCode        String
  documentNumber   String?
  note             String?
  bpCost           Decimal                        @default(0) @db.Decimal(14, 2)
  cuttingCost      Decimal                        @default(0) @db.Decimal(14, 2)
  shippingCost     Decimal                        @default(0) @db.Decimal(14, 2)
  woodPrice        Decimal                        @default(0) @db.Decimal(14, 2)
  grandTotal       Decimal                        @default(0) @db.Decimal(14, 2)
  vendor           Vendor                         @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  items             WoodPurchaseItem[]
  thicknessStocks   WoodPurchaseThicknessStock[]
  createdAt        DateTime                       @default(now())
  updatedAt        DateTime                       @updatedAt

  @@index([vendorId])
  @@index([purchaseDate])
}

/// Stok veneer (atau setara) per partai per nilai ketebalan — unit utama: qty per ketebalan.
model WoodPurchaseThicknessStock {
  id           String           @id @default(cuid())
  purchaseId   String
  thicknessMm  Decimal          @db.Decimal(10, 3)
  qtyAvailable Decimal          @default(0) @db.Decimal(12, 2)
  unit         String?
  purchase     WoodPurchase     @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  saleSources  SaleItemSource[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([purchaseId, thicknessMm])
  @@index([purchaseId])
}

model WoodPurchaseItem {
  id              String           @id @default(cuid())
  purchaseId      String
  noKapling       String
  woodType        String
  sort            String?
  length          Decimal?         @db.Decimal(10, 2)
  diameter        Decimal?         @db.Decimal(10, 2)
  logQty          Decimal          @default(0) @db.Decimal(12, 2)
  volume          Decimal          @default(0) @db.Decimal(14, 3)
  mutu            String?
  status          String?
  amount          Decimal          @default(0) @db.Decimal(14, 2)
  remainingQty    Decimal          @default(0) @db.Decimal(12, 2)
  remainingVolume Decimal          @default(0) @db.Decimal(14, 3)
  note            String?
  purchase        WoodPurchase     @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  saleSources     SaleItemSource[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([purchaseId])
  @@index([woodType])
}

model Sale {
  id              String        @id @default(cuid())
  clientRequestId String?       @unique
  customerId      String?
  invoiceGroupId  String?
  saleDate        DateTime
  customerName    String?
  note            String?
  grandTotal      Decimal       @db.Decimal(14, 2)
  customer        Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  invoiceGroup    InvoiceGroup? @relation(fields: [invoiceGroupId], references: [id], onDelete: SetNull)
  saleItems       SaleItem[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([customerId])
  @@index([saleDate])
  @@index([invoiceGroupId])
}

/// Grup tagihan manual — beberapa penjualan customer yang sama digabung dengan kode invoice eksternal.
model InvoiceGroup {
  id                String               @id @default(cuid())
  customerId        String
  manualInvoiceCode String               @unique
  invoiceDate       DateTime
  totalAmount       Decimal              @db.Decimal(14, 2)
  paidAmount        Decimal              @default(0) @db.Decimal(14, 2)
  remainingAmount   Decimal              @db.Decimal(14, 2)
  paymentStatus     InvoicePaymentStatus @default(unpaid)
  notes             String?
  customer          Customer             @relation(fields: [customerId], references: [id], onDelete: Restrict)
  sales             Sale[]
  payments          InvoiceGroupPayment[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([customerId])
  @@index([invoiceDate])
  @@index([paymentStatus])
}

/// Catatan pelunasan per invoice group — jejak tanggal dan nominal tiap pembayaran.
model InvoiceGroupPayment {
  id             String       @id @default(cuid())
  invoiceGroupId String
  paymentDate    DateTime
  amount         Decimal      @db.Decimal(14, 2)
  notes          String?
  invoiceGroup   InvoiceGroup @relation(fields: [invoiceGroupId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([invoiceGroupId])
  @@index([paymentDate])
}

enum InvoicePaymentStatus {
  unpaid
  partial
  paid
}

model SaleItem {
  id        String           @id @default(cuid())
  saleId    String
  itemName  String
  category  String?
  thickness String?
  width     String?
  length    String?
  unit      String?
  qty       Decimal          @db.Decimal(12, 2)
  price     Decimal          @db.Decimal(14, 2)
  subtotal  Decimal          @db.Decimal(14, 2)
  note      String?
  sale      Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade)
  sources   SaleItemSource[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  product   Product?         @relation(fields: [productId], references: [id])
  productId String?

  @@index([saleId])
}

/// Alokasi sumber: alokasi baru memakai thicknessStockId (stok per partai + ketebalan).
/// Baris riwayat lama memakai purchaseItemId (baris log/kapling) — tetap dibaca, tidak dicampur stok ketebalan.
model SaleItemSource {
  id               String                        @id @default(cuid())
  saleItemId       String
  purchaseItemId   String?
  thicknessStockId String?
  qtyTaken         Decimal                       @default(0) @db.Decimal(12, 2)
  volumeTaken      Decimal                       @default(0) @db.Decimal(14, 3)
  costAmount       Decimal                       @default(0) @db.Decimal(14, 2)
  saleItem         SaleItem                      @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  purchaseItem     WoodPurchaseItem?             @relation(fields: [purchaseItemId], references: [id], onDelete: Restrict)
  thicknessStock   WoodPurchaseThicknessStock?   @relation(fields: [thicknessStockId], references: [id], onDelete: Restrict)
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt

  @@index([saleItemId])
  @@index([purchaseItemId])
  @@index([thicknessStockId])
}
